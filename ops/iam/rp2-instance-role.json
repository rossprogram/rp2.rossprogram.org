{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SESSendFromUsEast1",
      "Effect": "Allow",
      "Action": ["ses:SendEmail", "ses:SendRawEmail"],
      "Resource": "*",
      "Condition": {
        "StringEquals": { "aws:RequestedRegion": "us-east-1" }
      }
    },
    {
      "Sid": "S3ListBuckets",
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:GetBucketLocation"],
      "Resource": [
        "arn:aws:s3:::rp2.rossprogram.org",
        "arn:aws:s3:::rp2-dev.rossprogram.org"
      ]
    },
    {
      "Sid": "S3Objects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload"
      ],
      "Resource": [
        "arn:aws:s3:::rp2.rossprogram.org/*",
        "arn:aws:s3:::rp2-dev.rossprogram.org/*"
      ]
    }
  ]
}
