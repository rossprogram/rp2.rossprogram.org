NODE_ENV=development
PORT=3000
HOST=127.0.0.1

DATABASE_URL=./dev.sqlite

APP_URL=http://localhost:5173

# 32+ char random string. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string-please-32-chars-min

EMAIL_FROM=noreply@rossprogram.org
EMAIL_TRANSPORT=console
SES_REGION=us-east-1

# Uploads. STORAGE_DRIVER=local writes to STORAGE_LOCAL_DIR (dev).
# STORAGE_DRIVER=s3 uses STORAGE_S3_BUCKET + STORAGE_S3_REGION (prod).
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=us-east-2
STORAGE_S3_PREFIX=uploads/
