NODE_ENV=production
PORT=3000
HOST=127.0.0.1

# SQLite lives on the EBS volume, on a path the systemd unit is allowed to write.
DATABASE_URL=/var/lib/rp2/db.sqlite

APP_URL=https://rp2.rossprogram.org

# 64-char hex. Generate: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_openssl_rand_hex_32

# SES (us-east-1). No AWS_ACCESS_KEY_ID — the EC2 instance role provides
# credentials via IMDS. The SDK picks them up automatically.
EMAIL_FROM=noreply@rossprogram.org
EMAIL_TRANSPORT=ses
SES_REGION=us-east-1

# S3 uploads (us-east-2). Same story — instance role, no keys.
STORAGE_DRIVER=s3
STORAGE_S3_BUCKET=rp2.rossprogram.org
STORAGE_S3_REGION=us-east-2
STORAGE_S3_PREFIX=uploads/
